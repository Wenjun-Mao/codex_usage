{
  "name": "codex-usage-dashboard",
  "displayName": "Codex Usage Dashboard",
  "description": "Local dashboard for Codex token usage from session JSONL logs.",
  "publisher": "local-codex-usage",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onCommand:codexUsage.openDashboard",
    "onCommand:codexUsage.refreshDashboard",
    "onCommand:codexUsage.openSettings",
    "onCommand:codexUsage.selectRange",
    "onCommand:codexUsage.selectProjects"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexUsage.openDashboard",
        "title": "Codex Usage: Open Dashboard"
      },
      {
        "command": "codexUsage.refreshDashboard",
        "title": "Codex Usage: Refresh Dashboard"
      },
      {
        "command": "codexUsage.openSettings",
        "title": "Codex Usage: Open Settings"
      },
      {
        "command": "codexUsage.selectRange",
        "title": "Codex Usage: Select Range"
      },
      {
        "command": "codexUsage.selectProjects",
        "title": "Codex Usage: Select Projects"
      }
    ],
    "configuration": {
      "title": "Codex Usage",
      "properties": {
        "codexUsage.range": {
          "type": "string",
          "enum": [
            "today",
            "yesterday",
            "7d",
            "30d",
            "month",
            "all"
          ],
          "default": "30d",
          "description": "Time range used when generating the dashboard report."
        },
        "codexUsage.sessionsDir": {
          "type": "string",
          "default": "",
          "description": "Optional path to the Codex sessions directory. Leave empty to use Python CLI auto-discovery."
        },
        "codexUsage.subscriptionUsd": {
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "minimum": 0,
          "description": "Optional monthly subscription amount for API-equivalent cost comparison."
        },
        "codexUsage.projectKeys": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Project keys selected for dashboard filtering. Leave empty to show all projects."
        }
      }
    }
  },
  "scripts": {
    "build:python:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\..\\scripts\\build-windows-exe.ps1",
    "build": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run build && node --test test/*.test.js",
    "package:vsix": "npm run package:vsix:win",
    "package:vsix:win": "npm run build:python:win && vsce package --target win32-x64 --out ../../output/codex-usage-dashboard-win32-x64.vsix --allow-missing-repository",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.7.2"
  }
}

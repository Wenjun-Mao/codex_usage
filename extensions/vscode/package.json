{
  "name": "codex-usage-dashboard",
  "displayName": "Codex Usage Dashboard",
  "description": "Local dashboard for Codex token usage, project rollups, and API-equivalent cost estimates.",
  "publisher": "wenjun-mao",
  "version": "0.1.29",
  "preview": true,
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wenjun-Mao/codex_usage.git"
  },
  "bugs": {
    "url": "https://github.com/Wenjun-Mao/codex_usage/issues"
  },
  "homepage": "https://github.com/Wenjun-Mao/codex_usage#readme",
  "keywords": [
    "codex",
    "tokens",
    "usage",
    "dashboard",
    "cost"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "virtualWorkspaces": false,
    "untrustedWorkspaces": {
      "supported": true,
      "description": "Codex Usage reads local Codex session storage and does not execute workspace code."
    }
  },
  "activationEvents": [
    "onCommand:codexUsage.openDashboard",
    "onCommand:codexUsage.refreshDashboard",
    "onCommand:codexUsage.openSettings",
    "onCommand:codexUsage.selectRange",
    "onCommand:codexUsage.selectProjects",
    "onCommand:codexUsage.selectTheme",
    "onCommand:codexUsage.reviewProjectTransitions",
    "onCommand:codexUsage.openSyncMenu",
    "onCommand:codexUsage.configureSync",
    "onCommand:codexUsage.selectSyncProjects",
    "onCommand:codexUsage.selectSyncThreads",
    "onCommand:codexUsage.syncNow",
    "onCommand:codexUsage.syncStatus",
    "onCommand:codexUsage.openSyncFolder",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexUsage.openDashboard",
        "title": "Codex Usage: Open Dashboard"
      },
      {
        "command": "codexUsage.refreshDashboard",
        "title": "Codex Usage: Refresh Dashboard"
      },
      {
        "command": "codexUsage.openSettings",
        "title": "Codex Usage: Open Settings"
      },
      {
        "command": "codexUsage.selectRange",
        "title": "Codex Usage: Select Range"
      },
      {
        "command": "codexUsage.selectProjects",
        "title": "Codex Usage: Select Projects"
      },
      {
        "command": "codexUsage.selectTheme",
        "title": "Codex Usage: Select Theme"
      },
      {
        "command": "codexUsage.reviewProjectTransitions",
        "title": "Codex Usage: Review Project Transitions"
      },
      {
        "command": "codexUsage.openSyncMenu",
        "title": "Codex Usage: Sync Menu"
      },
      {
        "command": "codexUsage.configureSync",
        "title": "Codex Usage: Configure Sync"
      },
      {
        "command": "codexUsage.selectSyncProjects",
        "title": "Codex Usage: Select Sync Projects"
      },
      {
        "command": "codexUsage.selectSyncThreads",
        "title": "Codex Usage: Select Sync Conversations"
      },
      {
        "command": "codexUsage.syncNow",
        "title": "Codex Usage: Sync Now"
      },
      {
        "command": "codexUsage.syncStatus",
        "title": "Codex Usage: Sync Status"
      },
      {
        "command": "codexUsage.openSyncFolder",
        "title": "Codex Usage: Open Sync Folder"
      }
    ],
    "configuration": {
      "title": "Codex Usage",
      "properties": {
        "codexUsage.range": {
          "type": "string",
          "enum": [
            "today",
            "yesterday",
            "7d",
            "30d",
            "month",
            "all"
          ],
          "default": "30d",
          "description": "Time range used when generating the dashboard report."
        },
        "codexUsage.theme": {
          "type": "string",
          "enum": [
            "auto",
            "day",
            "night"
          ],
          "default": "auto",
          "description": "Dashboard theme. Auto follows the active VS Code theme in the extension and system preference for standalone HTML."
        },
        "codexUsage.projectTransitions.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically split usage when high-confidence local repository transitions are detected."
        },
        "codexUsage.sync.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable experimental Codex sync for manual Sync Now and optional automatic pull/push."
        },
        "codexUsage.sync.autoPull": {
          "type": "boolean",
          "default": true,
          "description": "Optional automatic pull of selected conversation updates when VS Code activates or gains focus. Turn off for manual-only sync."
        },
        "codexUsage.sync.autoPush": {
          "type": "boolean",
          "default": true,
          "description": "Optional automatic push of selected conversation updates after watched Codex session files change. Turn off for manual-only sync."
        }
      }
    }
  },
  "scripts": {
    "build:python:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\..\\scripts\\build-windows-exe.ps1",
    "build": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run build && node --test test/*.test.js",
    "package:vsix": "npm run package:vsix:win",
    "package:vsix:win": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"New-Item -ItemType Directory -Force ..\\..\\output | Out-Null\" && npm run build:python:win && vsce package --target win32-x64 --out ../../output/codex-usage-dashboard-win32-x64.vsix",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.7.2"
  }
}
